{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/preview",
      "dest": "/preview"
    },
    {
      "src": "/mon-compte",
      "dest": "/mon-compte"
    },
    {
      "src": "/fresque",
      "dest": "/fresque"
    },
    {
      "src": "/foodtruck",
      "dest": "/foodtruck"
    },
    {
      "src": "/educolab",
      "dest": "/educolab"
    },
    {
      "src": "/contact",
      "dest": "/contact"
    },
    {
      "src": "/connexion",
      "dest": "/connexion"
    },
    {
      "src": "/admin/prescripteurs",
      "dest": "/admin/prescripteurs"
    },
    {
      "src": "/admin/inscriptions",
      "dest": "/admin/inscriptions"
    },
    {
      "src": "/admin",
      "dest": "/admin"
    },
    {
      "src": "/actions",
      "dest": "/actions"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/ressources/(?<id>[^/]+)",
      "dest": "/ressources/[id]"
    },
    {
      "src": "/actions/(?<id>[^/]+)",
      "dest": "/actions/[id]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}