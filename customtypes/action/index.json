{
  "id": "action",
  "label": "Action",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": { "type": "UID", "config": { "label": "URL Slug" } },
      "title": { "type": "Text", "config": { "label": "Titre", "placeholder": "Titre de l'action" } },
      "category": {
        "type": "Select",
        "config": {
          "label": "Catégorie",
          "options": [
            "Bien-être", "Découverte & orientation", "Vie quotidienne",
            "Formations", "Formations & Ateliers", "Rencontres/Visites",
            "Mobilité", "Emploi", "Numérique", "Droits", "Bénévolat"
          ]
        }
      },
      "date_text": { "type": "Text", "config": { "label": "Date", "placeholder": "Toute l'année ou 27/03/2026" } },
      "time_text": { "type": "Text", "config": { "label": "Horaire", "placeholder": "13:30 - 15:30" } },
      "summary": { "type": "Text", "config": { "label": "Résumé court" } },
      "description": { "type": "StructuredText", "config": { "label": "Description", "multi": "paragraph,heading3,heading4,heading5,heading6,strong,em,hyperlink,list-item,o-list-item" } },
      "url_detail": { "type": "Link", "config": { "label": "Lien détail (site Prado)" } },
      "image": { "type": "Image", "config": { "label": "Image" } },
      "is_activite": { "type": "Boolean", "config": { "label": "Est une activité datée", "default_value": false } },
      "original_id": { "type": "Number", "config": { "label": "ID original (migration)" } }
    }
  }
}
